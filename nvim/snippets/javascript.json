{
  "Console log": {
    "prefix": "cl",
    "body": "console.log(${1:value});",
    "description": "Insert console.log"
  },
  "Arrow function": {
    "prefix": "af",
    "body": "const ${1:name} = (${2:args}) => {\n\t${0}\n};",
    "description": "Create an arrow function"
  },
  "React component": {
    "prefix": "rfc",
    "body": [
      "export function ${1:ComponentName}(${2:props}) {",
      "\treturn (",
      "\t\t${0:<div />}",
      "\t);",
      "}"
    ],
    "description": "Create a React function component"
  }
}
